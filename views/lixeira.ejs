<!doctype html>
<html lang="pt-BR" data-bs-theme="light">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <script>
    const temaSalvo = localStorage.getItem('theme') || 'light';
    document.documentElement.setAttribute('data-bs-theme', temaSalvo);
  </script>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
  <link href="/lixeira.css" rel="stylesheet">

  <title>NotesBlock - Lixeira</title>
</head>

<body>
  <nav class="navbar bg-body-tertiary border-end fixed-top d-flex flex-column align-items-start p-3"
    style="width: 250px; height: 100vh;">
    <div class="container-fluid d-flex flex-column align-items-start p-0">

      <a class="navbar-brand mb-0 h1 d-flex align-items-center" href="/principal">
        NotesBlock
      </a>

      <ul class="navbar-nav me-auto mb-lg-0 w-100">
        <li class="nav-item">
          <a class="nav-link" href="/user/perfil"> 👤 Perfil</a>
        </li>
        <li class="nav-item">
          <a class="nav-link active" href="/lixeira">🗑️ Lixeira</a>
        </li>
        <li class="nav-item mt-3">
          <a class="nav-link text-danger fw-semibold" href="/user/logout">🚪 Sair da Conta</a>
        </li>
      </ul>
    </div>

    <div class="d-flex align-items-center mt-auto dropup style-dropup-container">
      <button class="btn theme-toggle mb-0 shadow-sm" type="button" data-bs-toggle="dropdown">
        🎨 Temas
      </button>
      <ul class="dropdown-menu themes-list w-100">
        <li><a class="dropdown-item" href="#" data-theme="light">🌞 Light</a></li>
        <li><a class="dropdown-item" href="#" data-theme="dark">🌙 Dark</a></li>
      </ul>
    </div>
  </nav>

  <div class="main-content" style="margin-left: 250px; padding: 2rem;">
    <h1 class="fw-bold mb-0">Lixeira</h1>

    <div class="d-flex flex-wrap gap-2 mt-3 mb-5">
      <form action="/lixeira/esvaziar" method="POST">
        <button class="btn btn-outline-danger shadow-sm" type="submit">Apagar tudo permanentemente</button>
      </form>

      <form action="/lixeira/restaurar-tudo" method="POST">
        <button class="btn btn-outline-secondary shadow-sm" type="submit">Restaurar tudo</button>
      </form>
    </div>

    <div class="container p-0">
      <div class="d-flex flex-wrap gap-4">

        <% if (notas.length===0) { %>
          <p class="text-muted">A lixeira está vazia.</p>
          <% } %>

            <% notas.forEach(function(nota) { %>
              <div class="d-flex flex-column" style="width: 200px;">
                <span class="fs-5 fw-medium d-block mb-2 text-truncate" title="<%= nota.titulo %>">
                  <%= nota.titulo %>
                </span>

                <button
                  class="btn bg-body-tertiary border p-4 d-flex align-items-center justify-content-center flex-column rounded-3 shadow-sm text-start align-self-stretch text-center"
                  style="height: 180px; width: 100%;" type="button" data-bs-toggle="modal"
                  data-bs-target="#modal-<%= nota._id %>">
                  <span class="fs-6 text-muted mb-2">Excluída</span>
                  <small class="text-primary fw-medium text-decoration-underline" style="font-size: 0.75rem;">Clique
                    para ler</small>
                </button>

                <form action="/lixeira/restaurar/<%= nota._id %>" method="POST" class="w-100 mt-2">
                  <button type="submit" class="btn btn-sm btn-primary w-100 shadow-sm">Restaurar</button>
                </form>
              </div>

              <div class="modal fade" id="modal-<%= nota._id %>" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
                  <div class="modal-content">
                    <div class="modal-header">
                      <h5 class="modal-title fw-bold">
                        <%= nota.titulo %>
                      </h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                    </div>
                    <div class="modal-body">
                      <div class="note-preview-content">
                        <%- nota.conteudo || '<i class="text-muted">Nota sem conteúdo...</i>' %>
                      </div>
                    </div>
                    <div class="modal-footer bg-body-tertiary">
                      <form action="/lixeira/restaurar/<%= nota._id %>" method="POST" class="w-100 m-0">
                        <button type="submit" class="btn btn-primary w-100">Restaurar Nota</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
              <% }); %>

      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const temaSalvo = localStorage.getItem('theme') || 'light';
      document.documentElement.setAttribute('data-bs-theme', temaSalvo);
    });

    document.querySelectorAll('.dropdown-item').forEach(item => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        const temaSelecionado = e.target.getAttribute('data-theme');
        document.documentElement.setAttribute('data-bs-theme', temaSelecionado);
        localStorage.setItem('theme', temaSelecionado);
      });
    });
  </script>
</body>

</html>