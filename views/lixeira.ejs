<!doctype html>
<html lang="pt-BR" data-bs-theme="light">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  
  <script>
    const temaSalvo = localStorage.getItem('theme') || 'light';
    document.documentElement.setAttribute('data-bs-theme', temaSalvo);
  </script>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
  <link href="/lixeira.css" rel="stylesheet">

  <title>NotesBlock - Lixeira</title>
</head>

<body>
  <nav class="navbar bg-body-tertiary border-end fixed-top d-flex flex-column align-items-start p-3" style="width: 250px; height: 100vh;">
    <div class="container-fluid d-flex flex-column align-items-start p-0">

      <a class="navbar-brand mb-0 h1 d-flex align-items-center" href="/principal">
        NotesBlock
      </a>

      <ul class="navbar-nav me-auto mb-lg-0 w-100">
        <li class="nav-item">
          <a class="nav-link" href="/user/perfil"> 👤 Perfil</a>
        </li>
        <li class="nav-item">
          <a class="nav-link active" href="/lixeira">🗑️ Lixeira</a>
        </li>
        <li class="nav-item mt-3">
          <a class="nav-link text-danger fw-semibold" href="/user/logout">🚪 Sair da Conta</a>
        </li>
      </ul>
    </div>

    <div class="d-flex align-items-center mt-auto dropup style-dropup-container">
      <button class="btn theme-toggle mb-0 shadow-sm" type="button" data-bs-toggle="dropdown">
        🎨 Temas
      </button>
      <ul class="dropdown-menu themes-list w-100">
        <li><a class="dropdown-item" href="#" data-theme="light">🌞 Light</a></li>
        <li><a class="dropdown-item" href="#" data-theme="dark">🌙 Dark</a></li>
      </ul>
    </div>
  </nav>

  <div class="main-content" style="margin-left: 250px; padding: 2rem;">
    <h1 class="fw-bold mb-0">Lixeira</h1>
    
    <div class="d-flex flex-wrap gap-2 mt-3 mb-5">
      <form action="/lixeira/esvaziar" method="POST">
        <button class="btn btn-outline-danger shadow-sm" type="submit">Apagar tudo permanentemente</button>
      </form>
      
      <form action="/lixeira/restaurar-tudo" method="POST">
        <button class="btn btn-outline-secondary shadow-sm" type="submit">Restaurar tudo</button>
      </form>
    </div>
    
    <div class="container">
      <div class="d-flex flex-wrap gap-4">

        <% if (notas.length === 0) { %>
          <p class="text-muted">A lixeira está vazia.</p>
        <% } %>

        <% notas.forEach(function(nota) { %>
          <div style="width: 200px;">
            <span class="fs-5 fw-medium d-block mb-2 text-truncate"><%= nota.titulo %></span>
            <div class="btn-group w-100 shadow-sm rounded-3">
              <button class="btn btn-outline active p-4 d-flex align-items-center justify-content-center flex-column" style="height: 180px; width: 100%;" type="button">
                <span class="fs-6 text-muted mb-2">Excluída</span>
                <form action="/lixeira/restaurar/<%= nota.id %>" method="POST" style="display: inline;">
                  <button type="submit" class="btn btn-sm btn-primary">Restaurar</button>
                </form>
              </button>
            </div>
          </div>
        <% }); %>
        
      </div>
    </div>
  </div>

  <script>
  document.addEventListener('DOMContentLoaded', () => {
    const temaSalvo = localStorage.getItem('theme') || 'light';
    document.documentElement.setAttribute('data-bs-theme', temaSalvo);
  });

  document.querySelectorAll('.dropdown-item').forEach(item => {
    item.addEventListener('click', (e) => {
      e.preventDefault();
      const temaSelecionado = e.target.getAttribute('data-theme');
      
      document.documentElement.setAttribute('data-bs-theme', temaSelecionado);
      
      localStorage.setItem('theme', temaSelecionado);
    });
  });
</script>
</body>

</html>