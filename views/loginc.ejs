<!doctype html>
<html lang="pt-BR" data-bs-theme="light">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <link href="/login.css" rel="stylesheet">

    <title>NotesBlock</title>
</head>

<body>

    <div class="d-flex flex-column align-items-center justify-content-center p-5" style="min-height: 95vh;">

        <h1 class="fw-bold mb-5 text-center">Faça seu login no NotesBlock!</h1>

        <div class="form-container w-100 bg-body-secondary rounded-3 shadow-lg p-4" style="max-width: 450px;">

            <form action="/login" method="POST">
                <div class="mb-3">
                    <label class="form-label fw-bold">E-mail</label>
                    <div class="form-floating">
                        <input type="email" class="form-control" id="floatingEmail" name="email"
                            placeholder="nome@exemplo.com" required>
                        <label for="floatingEmail">seu@email.com</label>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Senha</label>
                    <div class="form-floating">
                        <input type="password" class="form-control" id="floatingPassword" name="senha"
                            placeholder="Sua senha" required>
                        <label for="floatingPassword">mínimo 6 caracteres</label>
                    </div>
                </div>

                <% if (typeof erro !=='undefined' && erro) { %>
                    <div class="alert alert-danger alert-dismissible fade show fw-semibold text-center mb-3"
                        role="alert" style="font-size: 0.9rem; padding: 0.5rem 1rem;">
                        <%= erro %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"
                                onclick="this.parentElement.style.display='none'"
                                style="padding: 0.65rem 1rem;"></button>
                    </div>
                    <% } %>

                        <p class="text-center mt-3">
                            Não tem uma conta?
                            <button type="button" class="btn btn-link p-0 mb-1 text-decoration-none fw-semibold"
                                data-bs-toggle="modal" data-bs-target="#modalCadastro" href="/login">
                                Entrar
                            </button>
                        </p>

                        <button class="btn btn-primary btn-lg py-2 w-100" type="submit">Entrar</button>

                        <p class="text-body-secondary mt-4 mb-0 text-center">@NotesBlock</p>
            </form>
        </div>
    </div>


    <div class="modal fade" id="modalCadastro" tabindex="-1" aria-labelledby="modalCadastroLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content p-2">
                <div class="modal-header border-0">
                    <h1 class="modal-title h3 fw-bold mb-0" id="modalCadastroLabel">Faça seu cadastro</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">

                    <form action="/login/cadastro" method="POST">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nome de Usuário</label>
                            <div class="form-floating">
                                <input type="text" class="form-control" id="floatingUsername" name="nome"
                                    placeholder="Seu nome de usuário" required>
                                <label for="floatingUsername">Seu nome de usuário</label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">E-mail</label>
                            <div class="form-floating">
                                <input type="email" class="form-control" id="floatingCadastroEmail" name="email"
                                    placeholder="nome@exemplo.com" required>
                                <label for="floatingCadastroEmail">seu@email.com</label>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Senha</label>
                            <div class="form-floating">
                                <input type="password" class="form-control" id="floatingCadastroPassword" name="senha"
                                    placeholder="Sua senha" required>
                                <label for="floatingCadastroPassword">mínimo 6 caracteres</label>
                            </div>
                        </div>

                        <button class="btn btn-primary btn-lg py-2 w-100" type="submit"
                            href="login/cadastro">Cadastrar</button>

                        <p class="text-body-secondary mt-4 mb-0 text-center">@NotesBlock</p>
                    </form>
                </div>
            </div>
        </div>
    </div>


    <div class="theme-button-container dropdown position-fixed bottom-0 start-0 p-3">
        <button class="btn btn-outline-secondary theme-toggle shadow-sm" type="button" data-bs-toggle="dropdown">
            🎨 Temas
        </button>
        <ul class="dropdown-menu themes-list">
            <li><a class="dropdown-item" href="#" data-theme="light">🌞 Light</a></li>
            <li><a class="dropdown-item" href="#" data-theme="dark">🌙 Dark</a></li>
        </ul>
    </div>

    <script>
        document.querySelectorAll('.dropdown-item').forEach(item => {
            item.addEventListener('click', (e) => {
                e.preventDefault();
                const temaSelecionado = e.target.getAttribute('data-theme');
                document.documentElement.setAttribute('data-bs-theme', temaSelecionado);
            });
        });
    </script>
</body>

</html>