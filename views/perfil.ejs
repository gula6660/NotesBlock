<!doctype html>
<html lang="pt-BR" data-bs-theme="light">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
  <link href="/perfil.css" rel="stylesheet">
  <title>NotesBlock - Perfil</title>
</head>

<body>
  <nav class="navbar bg-body-tertiary border-end fixed-top d-flex flex-column align-items-start p-3"
    style="width: 250px; height: 100vh;">
    <div class="container-fluid d-flex flex-column align-items-start p-0">

      <a class="navbar-brand mb-0 h1 d-flex align-items-center" href="/principal">
        NotesBlock
      </a>

      <ul class="navbar-nav me-auto mb-lg-0 w-100">
        <li class="nav-item">
          <a class="nav-link active" href="/user/perfil"> 👤 Perfil</a>
        </li>

        <li class="nav-item">
          <a class="nav-link" href="/lixeira">🗑️ Lixeira</a>
        </li>

        <li class="nav-item mt-3">
          <a class="nav-link text-danger fw-semibold" href="/user/logout">🚪 Sair da Conta</a>
        </li>

      </ul>
    </div>

    <div class="d-flex align-items-center mt-auto dropup style-dropup-container">
      <button class="btn theme-toggle mb-0 shadow-sm" type="button" data-bs-toggle="dropdown">
        🎨 Temas
      </button>
      <ul class="dropdown-menu themes-list w-100">
        <li><a class="dropdown-item" href="#" data-theme="light">🌞 Light</a></li>
        <li><a class="dropdown-item" href="#" data-theme="dark">🌙 Dark</a></li>
      </ul>
    </div>
  </nav>

  <div class="main-content" style="margin-left: 250px; padding: 2rem;">
    <h1 class="fw-bold mb-4">Perfil</h1>

    <div class="container d-flex flex-column align-items-start justify-content-center mt-5"
      style="max-width: 400px; margin-left: 0;">

      <div class="text-start mb-4 w-100">
        <span class="fs-6 text-muted">Nome</span>
        <span class="fs-5 fw-bold d-block mb-2">
          <%= user.nome %>
        </span>
        <button class="btn btn-outline-secondary btn-sm shadow-sm" type="button" data-bs-toggle="modal"
          data-bs-target="#modalNome">Mudar Nome</button>
      </div>

      <div class="text-start mb-4 w-100">
        <span class="fs-6 text-muted">E-mail</span>
        <span class="fs-5 fw-bold d-block mb-2">
          <%= user.email %>
        </span>
        <button class="btn btn-outline-secondary btn-sm shadow-sm" type="button" data-bs-toggle="modal"
          data-bs-target="#modalEmail">Mudar Email</button>
      </div>

      <div class="text-start mb-4 w-100">
        <span class="fs-6 text-muted">Senha</span>
        <span class="fs-5 fw-bold d-block mb-2">********</span>
        <button class="btn btn-outline-secondary btn-sm shadow-sm" type="button" data-bs-toggle="modal"
          data-bs-target="#modalSenha">Mudar Senha</button>
      </div>

    </div>
  </div>

  <div class="modal fade" id="modalNome" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <form action="/user/editar" method="POST" class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title fw-bold">Alterar Nome</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="form-floating">
            <input type="text" class="form-control" id="inputNovoNome" name="nome" placeholder="Novo Nome" required
              value="<%= user.nome %>">
            <label for="inputNovoNome">Digite o novo nome</label>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar Alterações</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal fade" id="modalEmail" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <form action="/user/editar" method="POST" class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title fw-bold">Alterar Email</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="form-floating">
            <input type="email" class="form-control" id="inputNovoEmail" name="email" placeholder="nome@exemplo.com"
              required value="<%= user.email %>">
            <label for="inputNovoEmail">Digite o novo e-mail</label>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar Alterações</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal fade" id="modalSenha" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <form action="/user/editar" method="POST" class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title fw-bold">Alterar Senha</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="form-floating mb-3">
            <input type="password" class="form-control" id="inputSenhaAtual" name="senhaAtual" placeholder="Senha Atual"
              required>
            <label for="inputSenhaAtual">Senha Atual</label>
          </div>
          <div class="form-floating">
            <input type="password" class="form-control" id="inputNovaSenha" name="novaSenha" placeholder="Nova Senha"
              required minlength="6">
            <label for="inputNovaSenha">Nova Senha (mínimo 6 caracteres)</label>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-primary">Salvar Alterações</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    document.querySelectorAll('.dropdown-item').forEach(item => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        const temaSelecionado = e.target.getAttribute('data-theme');
        document.documentElement.setAttribute('data-bs-theme', temaSelecionado);
      });
    });
  </script>
</body>

</html>