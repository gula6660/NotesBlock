<!doctype html>
<html lang="pt-BR" data-bs-theme="light">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
  <link href="/novanota.css" rel="stylesheet">
  
  <title>NotesBlock - Escrever Nota</title>
</head>

<body>
  <nav class="navbar bg-body-tertiary border-end fixed-top d-flex flex-column align-items-start p-3"
    style="width: 250px; height: 100vh;">
    <div class="container-fluid d-flex flex-column align-items-start p-0">
      <a class="navbar-brand mb-0 h1 d-flex align-items-center" href="#">
        <img src="C:\Users\LENOVO\Downloads\Design sem nome (1).jpg" width="30" height="30"
          class="d-inline-block align-top me-2" alt="">
        NotesBlock
      </a>

      <ul class="navbar-nav me-auto mb-lg-0">
        <li class="nav-item">
          <a class="nav-link active" aria-current="page" href="#">👤 Perfil</a>
        </li>
        <li class="nav-item">
          <a class="nav-link active" aria-current="page" href="#">🗑️ Lixeira</a>
        </li>
      </ul>
    </div>

    <div class="d-flex align-items-center mt-auto dropup style-dropup-container">
      <button class="btn theme-toggle mb-0 shadow-sm" type="button" data-bs-toggle="dropdown">
        🎨 Temas
      </button>
      <ul class="dropdown-menu themes-list w-100">
        <li><a class="dropdown-item" href="#" data-theme="light">🌞 Light</a></li>
        <li><a class="dropdown-item" href="#" data-theme="dark">🌙 Dark</a></li>
      </ul>
    </div>
  </nav>

  <div class="main-content" style="margin-left: 250px;">
    <div class="content-wrapper">
      <div class="editor-container p-4">
        
        <div class="row g-4">
          
          <div class="col-11">
            <input type="text" class="form-control title-input mb-4" id="noteTitle" placeholder="Digite o título da nota...">
            
            <div class="note-content mb-4" id="noteContent" contenteditable="true"></div>
          </div>

          <div class="col-1 d-flex flex-column align-items-center justify-content-start pt-2">
            <div class="toolbar-vertical d-flex flex-column gap-2 p-2 bg-body-secondary rounded-3 shadow-sm">
              
              <button type="button" class="btn btn-outline-secondary btn-tool" onclick="formatText('bold')" 
                data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="Negrito">
                <i class="bi bi-type-bold"></i>
              </button>
              
              <button type="button" class="btn btn-outline-secondary btn-tool" onclick="formatText('italic')" 
                data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="Itálico">
                <i class="bi bi-type-italic"></i>
              </button>
              
              <button type="button" class="btn btn-outline-secondary btn-tool" onclick="formatText('underline')" 
                data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="Sublinhado">
                <i class="bi bi-type-underline"></i>
              </button>
              
              <hr class="my-1 text-secondary w-100">
              
              <button type="button" class="btn btn-outline-secondary btn-tool" onclick="formatText('insertOrderedList')" 
                data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="Lista Numerada">
                <i class="bi bi-list-ol"></i>
              </button>
              
              <button type="button" class="btn btn-outline-secondary btn-tool" onclick="formatText('insertUnorderedList')" 
                data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="Lista com Marcadores">
                <i class="bi bi-list-ul"></i>
              </button>
              
              <hr class="my-1 text-secondary w-100">
              
              <button type="button" class="btn btn-outline-secondary btn-tool" onclick="formatText('justifyLeft')" 
                data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="Alinhar à Esquerda">
                <i class="bi bi-justify-left"></i>
              </button>
              
              <button type="button" class="btn btn-outline-secondary btn-tool" onclick="formatText('justifyCenter')" 
                data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="Centralizar">
                <i class="bi bi-justify-center"></i>
              </button>
              
              <button type="button" class="btn btn-outline-secondary btn-tool" onclick="formatText('justifyRight')" 
                data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="Alinhar à Direita">
                <i class="bi bi-justify-right"></i>
              </button>
              
              <hr class="my-1 text-secondary w-100">
              
              <button type="button" class="btn btn-outline-danger btn-tool" onclick="formatText('removeFormat')" 
                data-bs-toggle="tooltip" data-bs-placement="left" data-bs-title="Limpar Formatação">
                <i class="bi bi-eraser-fill"></i>
              </button>
              
            </div>
          </div>
        </div>

        <div class="d-flex justify-content-start gap-3 mt-3">
          <button class="btn btn-primary save-btn" onclick="saveNote()">
            💾 Salvar Nota
          </button>
          <button class="btn btn-outline-secondary save-btn" onclick="clearNote()">
            🗑️ Limpar
          </button>
        </div>
        
        <div id="feedbackMsg" class="alert mt-3" style="display: none;"></div>
      </div>
    </div>
  </div>
  
  <script>
    // Inicialização obrigatória dos Tooltips do Bootstrap 5
    document.addEventListener('DOMContentLoaded', function() {
      const tooltipTriggerList = document.querySelectorAll('[data-bs-toggle="tooltip"]');
      const tooltipList = [...tooltipTriggerList].map(tooltipTriggerEl => new bootstrap.Tooltip(tooltipTriggerEl));
    });

    function formatText(command) {
      if (command === 'removeFormat') {
        document.execCommand('removeFormat', false, null);
      } else {
        document.execCommand(command, false, null);
      }
      document.getElementById('noteContent').focus();
    }
    
    function saveNote() {
      const title = document.getElementById('noteTitle').value.trim();
      const content = document.getElementById('noteContent').innerHTML;
      const plainContent = document.getElementById('noteContent').innerText.trim();
      
      if (!title && plainContent === '') {
        showFeedback('⚠️ Por favor, adicione um título ou conteúdo para a nota!', 'warning');
        return;
      }
      if (!title) {
        showFeedback('⚠️ Por favor, adicione um título para a nota!', 'warning');
        return;
      }
      if (plainContent === '' || plainContent === 'Digite sua nota aqui... Use as ferramentas ao lado para formatar o texto!') {
        showFeedback('⚠️ Por favor, adicione algum conteúdo à nota!', 'warning');
        return;
      }
      
      const note = {
        id: Date.now(),
        title: title,
        content: content,
        plainContent: plainContent,
        date: new Date().toLocaleString('pt-BR'),
        type: 'rich-text'
      };
      
      let notes = JSON.parse(localStorage.getItem('notes') || '[]');
      notes.push(note);
      localStorage.setItem('notes', JSON.stringify(notes));
      
      showFeedback('✅ Nota salva com sucesso!', 'success');
    }
    
    function clearNote() {
      if (confirm('Tem certeza que deseja limpar tudo? O conteúdo não salvo será perdido.')) {
        document.getElementById('noteTitle').value = '';
        document.getElementById('noteContent').innerHTML = '';
        showFeedback('📝 Formulário limpo!', 'info');
        document.getElementById('noteTitle').focus();
      }
    }
    
    function showFeedback(message, type) {
      const feedback = document.getElementById('feedbackMsg');
      feedback.textContent = message;
      feedback.className = `alert alert-${type === 'success' ? 'success' : type === 'warning' ? 'warning' : 'info'} mt-3`;
      feedback.style.display = 'block';
      
      setTimeout(() => {
        feedback.style.display = 'none';
      }, 3000);
    }
    
    document.addEventListener('DOMContentLoaded', function() {
      const noteContent = document.getElementById('noteContent');
      const placeholderText = 'Digite sua nota aqui... Use as ferramentas ao lado para formatar o texto!';
      
      noteContent.addEventListener('focus', function() {
        if (this.innerText === placeholderText) {
          this.innerHTML = '';
        }
      });
      
      noteContent.addEventListener('blur', function() {
        if (this.innerText.trim() === '') {
          this.innerHTML = placeholderText;
        }
      });
      
      if (noteContent.innerText.trim() === '') {
        noteContent.innerHTML = placeholderText;
      }
    });
    
    document.querySelectorAll('.dropdown-item').forEach(item => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        const temaSelecionado = e.target.getAttribute('data-theme');
        document.documentElement.setAttribute('data-bs-theme', temaSelecionado);
      });
    });
  </script>
</body>
</html>